GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=
# Optional: only needed if using agent identity features
GREENNODE_AGENT_IDENTITY=
# Optional: override local/runtime port
PORT=8000

# Persistent knowledge (AgentBase Memory Service).
# Required so trained knowledge survives restarts on the cloud runtime, where the
# local .agentbase/ volume is ephemeral and wiped on every restart.
# MUST be set in the deployed runtime env (the runtime does not read this .env file).
MEMORY_ID=
MEMORY_STRATEGY_ID=
# Optional: namespace actor (default: qc-shared)
MEMORY_ACTOR=
