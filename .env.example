GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=
# Optional: only needed if using agent identity features
GREENNODE_AGENT_IDENTITY=
# Optional: override local/runtime port
PORT=8000
# Optional: LLM configuration for AI-enhanced test case generation
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_WIRE_API=chat
# Optional: enable vision/OCR for image uploads (PNG, JPG, WebP)
# Requires LLM_WIRE_API=chat and a vision-capable model (e.g. gpt-4o, claude-3-5-sonnet)
# LLM_VISION_ENABLED=false
